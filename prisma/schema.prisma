generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String

  orders    Order[]
  responses Response[]
}

model Category {
  id     String  @id @default(cuid())
  nameRu String
  nameUz String
  orders Order[]
}

model Order {
  id          String   @id @default(cuid())
  title       String
  description String
  district    String
  budget      Int
  image       String?
  createdAt   DateTime @default(now())

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  
  responses   Response[] // Список откликов на этот заказ
}

model Response {
  id        String   @id @default(cuid())
  text      String
  price     Int
  createdAt DateTime @default(now())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}